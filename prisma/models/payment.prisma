model PaymentMethod {
  id       String  @id @default(uuid())
  name     String
  provider String // stripe, paypal, apple_pay, etc.
  isActive Boolean @default(true) @map("is_active")
  config   Json? // Store API keys, etc. (encrypt in production!)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  payments    Payment[]
  refunds     Refund[]
  paymentAuditLogs PaymentAuditLog[]

  @@map("payment_methods")
}

model Payment {
  id          String  @id @default(uuid())
  orderId     String  @map("order_id")
  amount      Decimal @db.Decimal(10, 2)
  currency    String  @default("USD")
  status      PaymentStatus
  provider    String
  transactionId String? @map("transaction_id")
  paymentMethodId String? @map("payment_method_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  paymentMethod PaymentMethod? @relation(fields: [paymentMethodId], references: [id])
  refunds       Refund[]

  @@map("payments")
}

model PaymentAuditLog {
  id          String  @id @default(uuid())
  orderId     String  @map("order_id")
  action      PaymentAuditAction // What happened
  amount      Decimal @db.Decimal(10, 2)
  currency    String  @default("USD")
  status      PaymentStatus
  provider    String
  transactionId String? @map("transaction_id")
  paymentMethodId String? @map("payment_method_id")

  // Audit metadata
  actorId     String? @map("actor_id") // User or system that triggered this
  actorType   String? @map("actor_type") // "USER", "SYSTEM", "WEBHOOK"
  metadata    Json? // Additional context about the action

  createdAt DateTime @default(now()) @map("created_at")
  // No updatedAt - audit logs are immutable

  order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  paymentMethod PaymentMethod? @relation(fields: [paymentMethodId], references: [id])

  @@map("payment_audit_logs")
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentAuditAction {
  PAYMENT_CREATED
  PAYMENT_UPDATED
  PAYMENT_COMPLETED
  PAYMENT_FAILED
  REFUND_INITIATED
  REFUND_COMPLETED
  REFUND_FAILED
  STATUS_CHANGED
  WEBHOOK_RECEIVED
}